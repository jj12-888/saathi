/* ─── BACKEND (Anthropic API) ─────────────────────────────────────── */
async function callChatbot(messages) {
  const systemPrompt = `You are Saathi Mitra, a deeply compassionate and gentle mental wellness companion for senior citizens in India. 
You speak with warmth, patience, and genuine care. You understand the emotional landscape of older adults — loneliness, health worries, family distance, grief, and the beautiful wisdom they carry.
You respond in a calm, unhurried tone. Occasionally use gentle Hindi phrases like "Aap bilkul akele nahi hain" (You are not alone at all). 
Keep responses to 2-3 sentences — warm, meaningful, not overwhelming. Never give medical advice. Always validate feelings first.`;

  const res = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      model: "claude-sonnet-4-20250514",
      max_tokens: 1000,
      system: systemPrompt,
      messages: messages.map(m => ({ role: m.from === "user" ? "user" : "assistant", content: m.text }))
    })
  });
  const data = await res.json();
  return data.content?.[0]?.text || "I am here with you. Please share what is on your heart.";
}

/* ─── SIMPLE IN-MEMORY BACKEND ────────────────────────────────────── */
let DB = {
  users: {},
  connections: [],
};

function dbSave(uid, profile) { DB.users[uid] = { ...DB.users[uid], ...profile, updatedAt: Date.now() }; }
function dbGet(uid) { return DB.users[uid] || null; }
function dbRegister(phone, name, password) {
  const uid = "u_" + Date.now();
  DB.users[uid] = { uid, phone, name, password, createdAt: Date.now(), connections: [] };
  return uid;
}
function dbLogin(phone, password) {
  return Object.values(DB.users).find(u => u.phone === phone && u.password === password) || null;
}
function dbConnect(uid, profileId) {
  if (!DB.users[uid]) return;
  DB.users[uid].connections = [...(DB.users[uid].connections || []), profileId];
}

