            ].map(n => (
              <button key={n.id} className={`nav-item ${activeTab===n.id?"active":""}`} onClick={() => setActiveTab(n.id)}>
                <span className="nav-icon">{n.icon}</span>
                <span>{n.label}</span>
              </button>
            ))}
          </div>
        </div>
      )}

      {/* ── EDIT PROFILE MODAL ── */}
      {editMode && (
        <div className="anim-fadeIn" style={{ position:"fixed", inset:0, background:"rgba(61,53,48,0.5)", backdropFilter:"blur(8px)", zIndex:300, display:"flex", alignItems:"flex-end" }}>
          <div className="anim-slideIn glass-card" style={{ width:"100%", maxWidth:540, margin:"0 auto", borderRadius:"28px 28px 0 0", padding:"32px 28px 40px", maxHeight:"90vh", overflowY:"auto" }}>
            <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:24 }}>
              <h2 style={{ fontFamily:"'Cormorant Garamond',serif", fontSize:26, fontWeight:600, color:"var(--text)" }}>Edit Your Profile</h2>
              <button className="soft-btn" onClick={() => setEditMode(false)} style={{ background:"var(--sage-pale)", border:"none", borderRadius:10, width:36, height:36, fontSize:18, display:"flex", alignItems:"center", justifyContent:"center" }}>×</button>
            </div>

            <div style={{ display:"flex", flexDirection:"column", gap:16 }}>
              <div>
                <label style={{ fontSize:12, fontWeight:700, color:"var(--stone)", letterSpacing:1, textTransform:"uppercase", display:"block", marginBottom:6 }}>Full Name</label>
                <input className="soft-input" value={editData.name||""} onChange={e => setEditData(d=>({...d,name:e.target.value}))} placeholder="Your full name" />
              </div>
              <div>
                <label style={{ fontSize:12, fontWeight:700, color:"var(--stone)", letterSpacing:1, textTransform:"uppercase", display:"block", marginBottom:6 }}>City / Location</label>
                <input className="soft-input" value={editData.location||""} onChange={e => setEditData(d=>({...d,location:e.target.value}))} placeholder="e.g. Basavanagudi, Bengaluru" />
              </div>
              <div>
                <label style={{ fontSize:12, fontWeight:700, color:"var(--stone)", letterSpacing:1, textTransform:"uppercase", display:"block", marginBottom:6 }}>About Me</label>
                <textarea className="soft-input" rows={4} value={editData.bio||""}
                  onChange={e => setEditData(d=>({...d,bio:e.target.value}))}
                  placeholder="Share a little about yourself, your story, and what makes you smile…"
                  style={{ resize:"vertical", lineHeight:1.7 }} />
              </div>
              <div>
                <label style={{ fontSize:12, fontWeight:700, color:"var(--stone)", letterSpacing:1, textTransform:"uppercase", display:"block", marginBottom:6 }}>Mobile Number</label>
                <input className="soft-input" type="tel" value={editData.phone||""} onChange={e => setEditData(d=>({...d,phone:e.target.value}))} placeholder="Your mobile number" />
              </div>

              {/* Interest tags */}
              <div>
                <label style={{ fontSize:12, fontWeight:700, color:"var(--stone)", letterSpacing:1, textTransform:"uppercase", display:"block", marginBottom:10 }}>My Interests</label>
                <div style={{ display:"flex", flexWrap:"wrap", gap:8 }}>
                  {["Bhajan & Kirtan","Kitty Parties","Chess","Yoga","Walking","Gardening","Cooking","Reading","Rangoli","Festivals","Music","Meditation","Card Games"].map(tag => {
                    const sel = (editData.interests||[]).includes(tag);
                    return (
                      <button key={tag} className="soft-btn" onClick={() => {
                        const cur = editData.interests || [];
                        setEditData(d => ({...d, interests: sel ? cur.filter(x=>x!==tag) : [...cur,tag] }));
                      }} style={{
                        padding:"7px 14px", borderRadius:20, fontSize:12, fontWeight:600,
                        background: sel ? "var(--sage)" : "var(--sage-pale)",
                        color: sel ? "white" : "var(--sage)",
                        border: sel ? "none" : "1px solid rgba(139,175,142,0.3)",
                        transition:"all 0.2s"
                      }}>{tag}</button>
                    );
                  })}
                </div>
              </div>

              <div style={{ display:"flex", gap:12, marginTop:8 }}>
                <button className="soft-btn primary-btn" style={{ flex:1 }} onClick={saveEdit}>Save Changes ✨</button>
                <button className="soft-btn outline-btn" style={{ flex:1, border:"1.5px solid var(--sage)" }} onClick={() => setEditMode(false)}>Cancel</button>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
